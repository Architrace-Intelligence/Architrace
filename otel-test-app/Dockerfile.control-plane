FROM eclipse-temurin:25-jdk AS build
WORKDIR /workspace

COPY . .

RUN chmod +x ./gradlew \
    && ./gradlew --no-daemon :control-plane:bootJar

FROM eclipse-temurin:25-jre
WORKDIR /app

COPY --from=build /workspace/architrace-control-plane/build/libs/*.jar /app/control-plane.jar

EXPOSE 8085 9090

ENTRYPOINT ["java", "-jar", "/app/control-plane.jar"]
