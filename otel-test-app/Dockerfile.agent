FROM eclipse-temurin:25-jdk AS build
WORKDIR /workspace

COPY . .

RUN chmod +x ./gradlew \
    && ./gradlew --no-daemon :agent:shadowJar

FROM eclipse-temurin:25-jre
WORKDIR /app

COPY --from=build /workspace/architrace-agent/build/libs/*-all.jar /app/agent.jar
COPY otel-test-app/architrace-agent.yaml /config/architrace-agent.yaml

EXPOSE 4319

ENTRYPOINT ["java", "--enable-preview", "-jar", "/app/agent.jar", "run", "--config", "/config/architrace-agent.yaml"]
